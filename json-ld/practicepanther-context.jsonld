{
  "@context": {
    "@version": 1.1,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "schema": "https://schema.org/",
    "pp": "https://app.practicepanther.com/api/",

    "Account": {
      "@id": "pp:account",
      "@type": "@id"
    },
    "Contact": {
      "@id": "schema:Person",
      "@type": "@id"
    },
    "Project": {
      "@id": "pp:project",
      "@type": "@id"
    },
    "Matter": {

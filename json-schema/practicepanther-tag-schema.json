{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/practicepanther/main/json-schema/practicepanther-tag-schema.json",
  "title": "Tag",
  "description": "JSON Schema for the PracticePanther Tag resource",
  "type": "object",
  "properties": {
    "guid": {
      "type": "string",
      "format": "uuid"
    },
    "id": {
      "type": "integer",
      "format": "int64"
    },
    "name": {
      "type": "string"
    },
    "accounts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Account"
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Project"
      }
    },
    "activities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Activity"
      }
    },
    "tenantId": {
      "type": "integer",
      "format": "int64"
    },
    "tenant": {
      "$ref": "#/$defs/Tenant"
    },
    "isEnabled": {
      "type": "boolean"
    },
    "isDeleted": {
      "type": "boolean"
    },
    "createdDate": {
      "type": "string",
      "format": "date-time"
    },
    "lastModifiedDate": {
      "type": "string",
      "format": "date-time"
    },
    "createdById": {
      "type": "integer",
      "format": "int32"
    },
    "createdBy": {
      "$ref": "#/$defs/User"
    },
    "lastModifiedById": {
      "type": "integer",
      "format": "int32"
    },
    "lastModifiedBy": {
      "$ref": "#/$defs/User"
    },
    "tagFor": {
      "type": "string",
      "enum": [
        "Account",
        "Project",
        "Activity"
      ]
    }
  }
}